# HYSA1 Environment Variables
# For production deployment on Render, set these in Render Environment Secrets

# PostgreSQL Database URL (from Supabase/Neon)
# Example for Supabase: postgresql://user:password@aws-0-us-west-1.pooler.supabase.com:5432/postgres
# Example for Neon: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb
DATABASE_URL=

# Cloudinary Credentials (for media storage)
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Server Configuration
PORT=3000
HOST=0.0.0.0

# Verified Users (comma-separated usernames)
VERIFIED_USERS=hysa,admin,psx

# Google Identity Services public client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gemini API key for backend-only HYSA AI
GEMINI_API_KEY=

# Buffer GraphQL API credentials for backend-only Ideas creation
BUFFER_ACCESS_TOKEN=
BUFFER_ORGANIZATION_ID=6a088dba9f5d1644db48e0c6

# HYSA AI Autonomous Content Scheduler
# Set to true to enable automatic content generation
HYSA_AI_AUTOPUBLISH_ENABLED=false
# Hours between each auto-generated post (minimum 1)
HYSA_AI_POST_INTERVAL_HOURS=6
# Maximum posts per day (1-10)
HYSA_AI_MAX_POSTS_PER_DAY=3
# Admin email for admin-only endpoints (optional, falls back to role check)
ADMIN_EMAIL=
