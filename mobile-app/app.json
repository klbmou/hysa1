{
  "expo": {
    "name": "HYSA1",
    "slug": "hysa1",
    "version": "0.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070711"
    },
    "android": {
      "package": "com.hysa.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#070711"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ]
    },
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-file-system",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow HYSA to access your camera for stories.",
          "microphonePermission": "Allow HYSA to record audio for video stories and voice messages.",
          "recordAudioAndroid": true
        }
      ],
      "expo-av"
    ],
    "extra": {
      "eas": {
        "projectId": "ee2a903b-ad5d-4899-987f-a7a53a945749"
      }
    },
    "owner": "yahiahabes"
  }
}
